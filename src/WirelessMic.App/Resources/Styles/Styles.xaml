<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============ Sayfa ============ -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
    </Style>

    <!-- ============ Tipografi ============ -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style x:Key="HeadlineXl" TargetType="Label">
        <Setter Property="FontFamily" Value="InterBold" />
        <Setter Property="FontSize" Value="40" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <!-- Geriye dönük: eski XAML "Headline" anahtarını kullanıyor -->
    <Style x:Key="Headline" TargetType="Label">
        <Setter Property="FontFamily" Value="InterBold" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style x:Key="SubHeadline" TargetType="Label">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style x:Key="BodyMuted" TargetType="Label">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource OnSurfaceVariant}" />
    </Style>

    <!-- Donanım "silkscreen" etiketi: BÜYÜK HARF + geniş harf aralığı -->
    <Style x:Key="LabelCaps" TargetType="Label">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="TextColor" Value="{StaticResource OnSurfaceVariant}" />
    </Style>

    <!-- Sayısal veri (tabular hissi) -->
    <Style x:Key="MonoData" TargetType="Label">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Secondary}" />
    </Style>

    <!-- ============ Kartlar (Glassmorphism) ============ -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassFillBrush}" />
        <Setter Property="Stroke" Value="{StaticResource GlassStrokeBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Shadow">
            <Shadow Brush="#000000" Radius="24" Opacity="0.45" Offset="0,10" />
        </Setter>
    </Style>

    <!-- İç öğe (liste satırı) kartı -->
    <Style x:Key="GlassTile" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#66171f33" />
        <Setter Property="Stroke" Value="{StaticResource GlassStrokeBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
    </Style>

    <!-- ============ Status Chip ============ -->
    <Style x:Key="StatusChip" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource ChipFill}" />
        <Setter Property="Stroke" Value="{StaticResource OutlineVariantBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- ============ Butonlar ============ -->
    <!-- Birincil tetikleyici: elektrik mavisi -> camgöbeği gradient, 24px squircle -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryGradient}" />
        <Setter Property="TextColor" Value="{StaticResource OnPrimary}" />
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="Scale" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.85" />
                            <Setter Property="Scale" Value="0.98" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.35" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Ghost buton: cam kenarlıklı, ikincil aksiyon -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="BorderColor" Value="{StaticResource Outline}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.7" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.3" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

</ResourceDictionary>
