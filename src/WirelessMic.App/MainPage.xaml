<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:WirelessMic.App.ViewModels"
             xmlns:dto="clr-namespace:WirelessMic.Application.DTO;assembly=WirelessMic.Application"
             x:Class="WirelessMic.App.MainPage"
             x:DataType="viewModels:MainViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Label Text="{Binding Title}"
                   Style="{StaticResource Headline}"
                   HorizontalOptions="Center" />

            <Border Stroke="{StaticResource Primary}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding DeviceRoleText}"
                           Style="{StaticResource SubHeadline}"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding PlatformText, StringFormat='Platform: {0}'}"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding StatusText}"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Gray500}" />

                    <Label Text="{Binding LatencyText}"
                           HorizontalOptions="Center"
                           IsVisible="{Binding IsConnected}"
                           TextColor="{StaticResource Primary}" />

                    <Label Text="Mikrofon aktif"
                           HorizontalOptions="Center"
                           IsVisible="{Binding IsMicrophoneActive}"
                           TextColor="{StaticResource Primary}"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsDesktop}">
                <Label Text="Masaüstü Modu"
                       FontAttributes="Bold" />
                <Label Text="{Binding VirtualMicrophoneHint}"
                       TextColor="{StaticResource Gray500}" />
                <Button Text="{Binding MicrophoneTestButtonText}"
                        Command="{Binding ToggleMicrophoneTestCommand}"
                        IsEnabled="{Binding IsVbCableReady}"
                        HorizontalOptions="Fill" />
                <Label Text="{Binding IsListening, StringFormat='Keşif dinleyici: {0}'}"
                       TextColor="{StaticResource Gray500}" />
                <Label Text="{Binding ConnectedClientCount, StringFormat='Bağlı cihaz: {0}'}"
                       TextColor="{StaticResource Gray500}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="12" IsVisible="{Binding IsPhone}">
                <Label Text="Telefon Modu"
                       FontAttributes="Bold" />
                <Label Text="Yakındaki bilgisayarları keşfedip mikrofon olarak bağlanacaksınız."
                       TextColor="{StaticResource Gray500}" />

                <Button Text="Bilgisayarları Ara"
                        Command="{Binding DiscoverServersCommand}"
                        HorizontalOptions="Fill" />

                <ActivityIndicator IsRunning="{Binding IsDiscovering}"
                                   IsVisible="{Binding IsDiscovering}"
                                   HorizontalOptions="Center" />

                <Label Text="Bulunan Bilgisayarlar"
                       FontAttributes="Bold"
                       IsVisible="{Binding HasDiscoveredServers}" />

                <CollectionView ItemsSource="{Binding DiscoveredServers}"
                                SelectedItem="{Binding SelectedServer}"
                                IsVisible="{Binding HasDiscoveredServers}"
                                SelectionMode="Single">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:DiscoveredServerDto">
                            <Border Stroke="{StaticResource Gray200}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="16"
                                    Margin="0,4">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding ComputerName}"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding IpAddress, StringFormat='IP: {0}'}"
                                           TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding Version, StringFormat='Sürüm: {0}'}"
                                           TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="Bağlan"
                        Command="{Binding ConnectToServerCommand}"
                        HorizontalOptions="Fill" />

                <ActivityIndicator IsRunning="{Binding IsConnecting}"
                                   IsVisible="{Binding IsConnecting}"
                                   HorizontalOptions="Center" />

                <Button Text="Bağlantıyı Kes"
                        Command="{Binding DisconnectCommand}"
                        IsVisible="{Binding IsConnected}"
                        HorizontalOptions="Fill"
                        BackgroundColor="{StaticResource Gray500}" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
